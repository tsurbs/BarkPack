# OpenRouter Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Slack Configuration
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your_signing_secret

# Server Configuration
HOST=0.0.0.0
PORT=8080

# Notion Configuration
NOTION_API_KEY=secret_your_notion_integration_token

# Context Engine Configuration
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# Vercel Configuration (for fullstack agent deployments)
VERCEL_TOKEN=your_vercel_token_here

# Google Drive Configuration (optional)
# GOOGLE_DRIVE_FOLDER_ID=your_folder_id
# GOOGLE_DRIVE_EXCLUDE_FOLDER_IDS=folder_id_1,folder_id_2

# FlareSolverr Configuration (optional — for Cloudflare-protected sites)
# FLARESOLVERR_URL=http://localhost:8191

# Claude Code Server (for self-modification)
CLAUDE_CODE_SERVER_URL=http://your-ec2-ip:9111
CLAUDE_CODE_AUTH_TOKEN=your-secret-token
