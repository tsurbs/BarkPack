# --- CORE SYSTEM ---
# Your OpenRouter API key for the orchestrator and all LLM agents.
# Get it at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# PostgreSQL database URL for long-term memory and vector search.
# If using the local docker-compose, this is the default:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/barkbot

# --- AUTHENTICATION (Optional for Local Dev) ---
# OIDC configuration for authenticating users across surfaces.
OIDC_CLIENT_ID=your_client_id
OIDC_ISSUER_URL=https://your-auth-provider.com/

# --- GOOGLE WORKSPACE AGENT ---
# OAuth 2.0 credentials for the bot's standard @gmail.com account.
# Run `uv run python scripts/generate_google_oauth_token.py` with your `credentials.json`
# to perform the 1-time login and generate the Refresh Token.
GOOGLE_CLIENT_ID=your_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_REFRESH_TOKEN=your_generated_perpetual_refresh_token

# --- KNOWLEDGE RETRIEVER AGENT ---
# Tavily API key for general web searching.
# Get it at: https://tavily.com/ (Developer Dashboard)
TAVILY_API_KEY=your_tavily_api_key_here

# Firecrawl API key for scraping and extracting website content.
# Get it at: https://firecrawl.dev/
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Notion Integration Token for searching internal wiki pages.
# Create an internal integration token at: https://www.notion.so/my-integrations
NOTION_API_KEY=your_notion_api_key_here

# --- GITHUB PM & SOFTWARE ENGINEER AGENTS ---
# GitHub Personal Access Token (Classic or Fine-Grained) with 'repo' and 'project' scopes.
# Required for creating issues, updating projects, and GitOps flows.
# Get it at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_pat_here

# --- RAILWAY DEPLOYMENTS (Software Engineer) ---
# Railway API token for deploying applications via the Railway CLI.
# Required if the Software Engineer agent is asked to deploy code.
# Get it at: https://railway.app/account/tokens
RAILWAY_TOKEN=your_railway_api_token_here

# --- SLACK INTEGRATION ---
# Credentials for the Slack App to receive events and send messages into channels.
# Required for `app/surfaces/slack.py` and `app/tools/slack_tools.py`
# Get them from your Slack API App configuration page: https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_SIGNING_SECRET=your_slack_signing_secret_here

